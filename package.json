{
  "name": "svg-peek",
  "displayName": "SVG Peek",
  "description": "Preview, format, and fold inline SVG in any file — without leaving the editor.",
  "version": "0.0.3",
  "publisher": "SvgPeek",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Papunidze/svg-peek.git"
  },
  "bugs": {
    "url": "https://github.com/Papunidze/svg-peek/issues"
  },
  "homepage": "https://github.com/Papunidze/svg-peek#readme",
  "keywords": [
    "svg",
    "preview",
    "hover",
    "inline",
    "gutter",
    "format",
    "fold"
  ],
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Visualization",
    "Formatters",
    "Other"
  ],
  "galleryBanner": {
    "color": "#F97316",
    "theme": "dark"
  },
  "activationEvents": [
    "onLanguage:svg",
    "onLanguage:xml",
    "onLanguage:html",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:vue",
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "svgPeek.foldAll",
        "title": "SVG Peek: Fold All SVGs in File"
      },
      {
        "command": "svgPeek.unfoldAll",
        "title": "SVG Peek: Unfold All SVGs in File"
      },
      {
        "command": "svgPeek.formatSvgs",
        "title": "SVG Peek: Format SVG Blocks in File"
      },
      {
        "command": "svgPeek.enableGutter",
        "title": "SVG Peek: Enable Gutter Thumbnails"
      },
      {
        "command": "svgPeek.disableGutter",
        "title": "SVG Peek: Disable Gutter Thumbnails"
      }
    ],
    "configuration": {
      "title": "SVG Peek",
      "properties": {
        "svgPeek.gutter.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Show a small thumbnail in the gutter next to each <svg>."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
